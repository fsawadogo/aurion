# Aurion — fastlane lanes
#
# Auth: all lanes use the App Store Connect API key (the same one CI
# uses, materialized from APP_STORE_CONNECT_KEY_ID / _ISSUER_ID /
# _KEY_P8 env vars). No 2FA prompts, no session cookies — works
# headless from a fresh shell.
#
# Run from the repo root:
#   cd ios/Aurion && fastlane bootstrap
#
# Lanes:
#   bootstrap                — create App IDs + ASC app record (one-time)
#   upload_testflight        — local build + TestFlight upload (mirror of CI)
#   invite_pilot_physicians  — add pilot physician emails as TestFlight testers
#   list_testers             — print current testers (sanity check)

# ---------------------------------------------------------------------------
# Auth helper — turns the 3 env vars into the hash fastlane expects.
# Decodes APP_STORE_CONNECT_KEY_P8 from base64 to a tempfile so the
# key never has to sit on disk in cleartext.
# ---------------------------------------------------------------------------
def asc_api_key
  raise "APP_STORE_CONNECT_KEY_ID is not set"     unless ENV["APP_STORE_CONNECT_KEY_ID"]
  raise "APP_STORE_CONNECT_ISSUER_ID is not set"  unless ENV["APP_STORE_CONNECT_ISSUER_ID"]
  raise "APP_STORE_CONNECT_KEY_P8 is not set"     unless ENV["APP_STORE_CONNECT_KEY_P8"]

  app_store_connect_api_key(
    key_id:      ENV["APP_STORE_CONNECT_KEY_ID"],
    issuer_id:   ENV["APP_STORE_CONNECT_ISSUER_ID"],
    key_content: Base64.decode64(ENV["APP_STORE_CONNECT_KEY_P8"]),
    duration:    1200,
    in_house:    false
  )
end

default_platform(:ios)

platform :ios do
  # -------------------------------------------------------------------------
  # bootstrap — one-time setup that creates the App IDs in the developer
  # portal + the App Store Connect app record. Idempotent: re-running
  # with an existing app/bundle is a no-op (fastlane checks first).
  # -------------------------------------------------------------------------
  desc "Create App IDs + App Store Connect app record (one-time)"
  lane :bootstrap do
    api_key = asc_api_key

    # 1. Main app — bundle id, App ID with Live Activities support,
    #    and the App Store Connect app record.
    produce(
      api_key:           api_key,
      app_identifier:    "com.aurionclinical.physician",
      app_name:          "Aurion",
      language:          "English",
      app_version:       "1.0",
      sku:               "aurion-pilot-001",
      skip_itc:          false,            # create ASC record
      skip_devcenter:    false,            # create App ID
      enable_services: {
        # Live Activities is enabled via NSSupportsLiveActivities in
        # Info.plist (already set) — no developer-portal capability
        # toggle. Push Notifications would be needed for push-updated
        # activities; we don't ship that path.
      }
    )

    # 2. Widget extension — bundle id only (extensions don't get ASC records).
    produce(
      api_key:           api_key,
      app_identifier:    "com.aurionclinical.physician.widgets",
      app_name:          "Aurion Widgets",
      sku:               "aurion-pilot-widgets-001",
      skip_itc:          true,             # extensions: no ASC record
      skip_devcenter:    false
    )

    UI.success "Bootstrap complete. App Store Connect record for 'Aurion' is ready."
    UI.message "Next: push an iOS-touching commit to main → ios-testflight.yml uploads the first build."
  end

  # -------------------------------------------------------------------------
  # upload_testflight — mirror of the CI workflow. Useful for a one-off
  # local upload when CI is wedged or for the very first build.
  # -------------------------------------------------------------------------
  desc "Build + upload to TestFlight (mirrors ios-testflight.yml)"
  lane :upload_testflight do
    api_key = asc_api_key

    # 1. Ensure an Apple Distribution certificate exists in the team and
    #    is installed in the local keychain. fastlane's `cert` action
    #    creates one via the API key if none exists and downloads the
    #    matching private key — this is what xcodebuild's
    #    -allowProvisioningUpdates flow is missing (it only creates
    #    Development certs, never Distribution).
    cert(
      api_key:     api_key,
      development: false                          # i.e. Distribution
    )

    # 2. Ensure App Store provisioning profiles exist for both targets.
    #    Distribution profiles don't need registered devices.
    sigh(
      api_key:        api_key,
      app_identifier: "com.aurionclinical.physician",
      development:    false,                      # implies App Store distribution
      force:          true                        # refresh on each run
    )
    sigh(
      api_key:        api_key,
      app_identifier: "com.aurionclinical.physician.widgets",
      development:    false,
      force:          true
    )

    # 3. Archive + export with explicit -allowProvisioningUpdates so
    #    gym picks up the profiles we just created.
    build_app(
      project:       "Aurion.xcodeproj",
      scheme:        "Aurion",
      configuration: "Release",
      export_method: "app-store",
      clean:         true,
      xcargs:        "-allowProvisioningUpdates"
    )

    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: true,
      skip_submission:                   true,    # don't ship to App Store
      distribute_external:               false
    )
  end

  # -------------------------------------------------------------------------
  # invite_pilot_physicians — add the pilot doctors as internal testers.
  # Emails come from ENV["PILOT_TESTER_EMAILS"] as a comma-separated list,
  # so the actual addresses aren't checked into git.
  # -------------------------------------------------------------------------
  desc "Invite pilot physicians as TestFlight internal testers"
  lane :invite_pilot_physicians do
    api_key = asc_api_key
    emails  = (ENV["PILOT_TESTER_EMAILS"] || "").split(",").map(&:strip).reject(&:empty?)

    if emails.empty?
      UI.user_error! "Set PILOT_TESTER_EMAILS=perry@creoq.ca,marie@creoq.ca (comma-separated)"
    end

    emails.each do |email|
      first, last = email.split("@").first.split(".")
      pilot(
        api_key:                  api_key,
        app_identifier:           "com.aurionclinical.physician",
        app_platform:             "ios",
        email:                    email,
        first_name:               first.to_s.capitalize,
        last_name:                (last || "Doctor").capitalize,
        distribute_only:          true,    # add-tester mode (no upload)
        notify_external_testers:  false    # we don't run external groups
      )
      UI.success "Invited #{email}"
    end
  end

  # -------------------------------------------------------------------------
  # distribute_latest — push the most recently uploaded build to TestFlight
  # external testers, AND log a confirmation that internal testers are
  # auto-served by Apple after processing.
  #
  # Apple's distribution model splits the two tiers:
  #
  # • INTERNAL testers = App Store Connect team members (Users and
  #   Access tab) with TestFlight access. Apple auto-delivers every
  #   processed build to them as soon as processing_state=VALID. There
  #   is NO build-assignment API for internal groups — Apple's API
  #   returns "Builds cannot be assigned to this internal group" /
  #   "Cannot add internal group to a build" if you try. To add new
  #   internal testers, invite them in App Store Connect → Users and
  #   Access → TestFlight role.
  #
  # • EXTERNAL testers = pilot physicians, beta participants. They
  #   need explicit group assignment + Beta App Review. This is the
  #   active surface this lane drives. The group is auto-created if
  #   missing; assignments + review submission run per dispatch.
  #
  # TESTFLIGHT_EXTERNAL_GROUP_NAME (default "Pilot Physicians") names
  # the external group. The legacy TESTFLIGHT_GROUP_NAME variable is
  # still honoured as a fallback. Set the value to an empty string to
  # skip external distribution (rare; would leave only internal
  # team-member auto-delivery active).
  # -------------------------------------------------------------------------
  desc "Distribute the latest uploaded build (external group + internal auto-delivery)"
  lane :distribute_latest do
    api_key = asc_api_key
    external_group_name = (ENV["TESTFLIGHT_EXTERNAL_GROUP_NAME"] || ENV["TESTFLIGHT_GROUP_NAME"] || "Pilot Physicians").strip
    build_number        = ENV["BUILD_NUMBER"] || ENV["GITHUB_RUN_NUMBER"]
    app_version         = ENV["APP_VERSION"]  || "1.0"
    UI.user_error!("BUILD_NUMBER / GITHUB_RUN_NUMBER not set") if build_number.nil?

    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id:    ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key:       Base64.decode64(ENV["APP_STORE_CONNECT_KEY_P8"]),
      duration:  1200,
    )
    app = Spaceship::ConnectAPI::App.find("com.aurionclinical.physician")
    UI.user_error!("App not found — run `fastlane bootstrap` first") unless app

    # ── Ensure the external group exists ──────────────────────────
    # Internal beta groups are not addressable via the API for build
    # assignment — Apple delivers builds to internal team members
    # automatically after processing. So we only create/use the
    # external group here.
    unless external_group_name.empty?
      existing = Spaceship::ConnectAPI.get_beta_groups(
        filter: { app: app.id }, limit: 200
      ).find { |g| g.name == external_group_name }

      if existing
        UI.success("Using existing external group '#{external_group_name}'")
      else
        UI.message("Creating external beta group '#{external_group_name}' (one-time)")
        # Raw POST so the body is exactly what Apple expects for an
        # external group (publicLink_* attributes allowed here).
        body = {
          data: {
            type: "betaGroups",
            attributes: {
              name:                   external_group_name,
              isInternalGroup:        false,
              publicLinkEnabled:      false,
              publicLinkLimit:        10_000,
              publicLinkLimitEnabled: false,
              hasAccessToAllBuilds:   false,
            },
            relationships: {
              app: { data: { type: "apps", id: app.id } },
            },
          },
        }
        Spaceship::ConnectAPI.client.test_flight_request_client.post(
          "v1/betaGroups", body
        )
      end
    end

    # ── Wait for Apple processing ─────────────────────────────────
    # altool returns when bytes are uploaded; Apple's processing
    # pipeline (transcode, malware scan, entitlements, beta-review
    # prep) takes another 5-15min before the build is VALID and
    # eligible for distribution. Without waiting, distribute prompts
    # interactively and crashes CI.
    UI.message "Waiting for build #{build_number} (v#{app_version}) to finish Apple processing…"
    deadline = Time.now + 1500   # 25min ceiling
    loop do
      builds = Spaceship::ConnectAPI.get_builds(
        filter:   { app: app.id, version: build_number },
        includes: "preReleaseVersion"
      )
      build = builds.first
      if build
        state = build.processing_state
        UI.message "  build state=#{state}"
        break if state == "VALID"
        UI.user_error!("Build processing #{state}") if %w[INVALID FAILED].include?(state)
      else
        UI.message "  build #{build_number} not yet visible in App Store Connect…"
      end
      UI.user_error!("Timed out waiting for build #{build_number} to process") if Time.now > deadline
      sleep 30
    end
    UI.success "Build #{build_number} is processed (VALID); distributing…"

    # ── Internal testers are auto-served by Apple ────────────────
    # No API call required: every App Store Connect team member with
    # TestFlight access receives the build automatically the moment
    # processing reaches VALID (just happened above).
    UI.success "Internal testers (App Store Connect team members) auto-receive build #{build_number} immediately."

    # ── Distribute to external (submits for Beta App Review) ──────
    unless external_group_name.empty?
      UI.message "Distributing to external group: '#{external_group_name}'"
      upload_to_testflight(
        api_key:                  api_key,
        app_identifier:           "com.aurionclinical.physician",
        app_platform:             "ios",
        app_version:              app_version,
        build_number:             build_number,
        distribute_only:          true,
        distribute_external:      true,
        groups:                   [external_group_name],
        notify_external_testers:  true,
        changelog:                "Latest Aurion build from main HEAD.",
      )
    end

    UI.success "Build #{build_number} distributed."
  end

  # -------------------------------------------------------------------------
  # invite_internal_testers — invite emails as App Store Connect team
  # members with the Customer Support role (the narrowest role that
  # grants TestFlight access). Once each invitee accepts the team
  # invite (manual email click), they become internal testers and can
  # be added to the "Pilot" internal beta group via
  # `add_to_pilot_internal`.
  #
  # Used for moving external pilot testers (in "Pilot Physicians") to
  # internal so they skip Apple's Beta App Review queue and receive
  # every processed build within minutes.
  #
  # Emails come from ENV["INVITE_EMAILS"] (comma-separated). The
  # lane is idempotent — if a user already exists on the team, we
  # log + skip rather than error out.
  # -------------------------------------------------------------------------
  desc "Invite emails as ASC team members (Customer Support role) for internal-tester access"
  lane :invite_internal_testers do
    emails = (ENV["INVITE_EMAILS"] || "").split(",").map(&:strip).reject(&:empty?)
    if emails.empty?
      UI.user_error!("Set INVITE_EMAILS=a@x.com,b@y.com (comma-separated)")
    end

    asc_api_key   # warm env defaults
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id:    ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key:       Base64.decode64(ENV["APP_STORE_CONNECT_KEY_P8"]),
      duration:  1200,
    )

    UI.success "Inviting #{emails.size} email(s) as Customer Support team members"
    emails.each do |email|
      # Derive a reasonable first/last from the email local-part so the
      # invite email doesn't read 'Dear ,'. ASC users can edit their
      # own name after accepting.
      local = email.split("@").first || email
      parts = local.split(/[._]/, 2)
      first = (parts[0] || "Pilot").capitalize
      last  = (parts[1] || "Physician").capitalize

      begin
        # UserInvitation (not User) is the right class for sending team
        # invites. Spaceship::ConnectAPI::User represents users that
        # already exist on the team; .create is not defined on it.
        Spaceship::ConnectAPI::UserInvitation.create(
          email:                 email,
          first_name:            first,
          last_name:             last,
          roles:                 ["CUSTOMER_SUPPORT"],
          provisioning_allowed:  false,
          all_apps_visible:      true,
        )
        UI.success "  ✓ invited #{email} (#{first} #{last})"
      rescue => e
        msg = e.message.to_s
        # Apple returns various error strings for the "already on the
        # team / invite already sent" cases; treat them all as soft skips.
        if msg.match?(/already exists|USER_INVITE_EXISTS|USER_ALREADY_EXISTS|USER_ASSOCIATION_ERROR|already an active user|email.*already/i)
          UI.message "  · #{email} already on the team or has a pending invite — skipping"
        else
          UI.error "  ✗ #{email} failed: #{msg.lines.first&.strip}"
          # Don't crash the whole lane on one bad email — surface + continue.
        end
      end
    end

    UI.success "Done. Each invitee receives an email; they must accept to become a team member."
    UI.message "Next: once they've accepted (visible in ASC → Users and Access)," \
               " run `add_to_pilot_internal` to put them in the Pilot internal beta group."
  end

  # -------------------------------------------------------------------------
  # add_to_pilot_internal — add already-team-member emails to the
  # "Pilot" internal beta group. Run after `invite_internal_testers`
  # once invitees have accepted the email.
  # -------------------------------------------------------------------------
  desc "Add team members to the Pilot internal beta group"
  lane :add_to_pilot_internal do
    emails = (ENV["INVITE_EMAILS"] || "").split(",").map(&:strip).reject(&:empty?)
    if emails.empty?
      UI.user_error!("Set INVITE_EMAILS=a@x.com,b@y.com (comma-separated)")
    end

    asc_api_key
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id:    ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key:       Base64.decode64(ENV["APP_STORE_CONNECT_KEY_P8"]),
      duration:  1200,
    )

    app = Spaceship::ConnectAPI::App.find("com.aurionclinical.physician")
    UI.user_error!("App not found") unless app

    pilot = Spaceship::ConnectAPI.get_beta_groups(
      filter: { app: app.id }, limit: 200
    ).find { |g| g.name == "Pilot" && g.is_internal_group }
    UI.user_error!("'Pilot' internal beta group not found") unless pilot

    UI.success "Adding #{emails.size} email(s) to internal group 'Pilot'"
    emails.each do |email|
      tester = Spaceship::ConnectAPI.get_beta_testers(
        filter: { email: email }, limit: 1
      ).first
      if tester.nil?
        UI.error "  ✗ #{email}: no BetaTester record (have they accepted the team invite?)"
        next
      end
      begin
        pilot.add_beta_testers(beta_tester_ids: [tester.id])
        UI.success "  ✓ added #{email}"
      rescue Spaceship::UnexpectedResponse => e
        UI.error "  ✗ #{email}: #{e.message.to_s.lines.first&.strip}"
      end
    end
  end

  # -------------------------------------------------------------------------
  # delete_empty_internal_group — remove an internal beta group that has
  # zero testers. Used for cleaning up leftover groups from earlier
  # TestFlight bring-up (e.g. "Aurion Internal" parked empty after the
  # internal-distribution path turned out to be auto-handled by ASC for
  # all team members).
  #
  # Safety guards:
  #   - Group name comes from ENV (GROUP_NAME), defaulting to "Aurion
  #     Internal" — explicit input so the lane can't accidentally delete
  #     "Pilot" or any other group with members.
  #   - Refuses to delete external groups (only `is_internal_group: true`
  #     are in scope here — external groups carry Beta App Review state
  #     that's painful to recreate).
  #   - By default, refuses to delete if the group has any testers. Prints
  #     the count and aborts. Pass FORCE_REMOVE_TESTERS=true to remove all
  #     testers from the group first; only meaningful for internal groups
  #     where every member is also in another group (otherwise you'd be
  #     stripping their TestFlight access).
  # -------------------------------------------------------------------------
  desc "Delete an internal beta group if it has zero testers"
  lane :delete_empty_internal_group do
    group_name = ENV["GROUP_NAME"] || "Aurion Internal"
    force_remove = %w[1 true yes].include?(ENV["FORCE_REMOVE_TESTERS"].to_s.downcase)

    asc_api_key
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id:    ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key:       Base64.decode64(ENV["APP_STORE_CONNECT_KEY_P8"]),
      duration:  1200,
    )

    app = Spaceship::ConnectAPI::App.find("com.aurionclinical.physician")
    UI.user_error!("App not found") unless app

    group = Spaceship::ConnectAPI.get_beta_groups(
      filter: { app: app.id }, limit: 200, includes: "betaTesters"
    ).find { |g| g.name == group_name }
    UI.user_error!("Beta group '#{group_name}' not found") unless group

    unless group.is_internal_group
      UI.user_error!("'#{group_name}' is an external group — this lane only deletes internal groups")
    end

    testers = group.beta_testers || []
    tester_count = testers.size
    if tester_count > 0
      if !force_remove
        UI.error "Refusing to delete '#{group_name}': it has #{tester_count} tester(s)."
        UI.error "Set FORCE_REMOVE_TESTERS=true to remove all testers first, or clear via dashboard."
        UI.user_error!("delete_empty_internal_group: group not empty")
      end

      UI.message "FORCE_REMOVE_TESTERS=true — removing #{tester_count} tester(s) from '#{group_name}'…"
      tester_ids = testers.map(&:id)
      testers.each { |t| UI.message "  · #{t.email}" }
      begin
        # remove_beta_testers is the parallel of add_beta_testers (we use
        # the latter in add_to_pilot_internal). The earlier `delete_beta_testers`
        # name doesn't exist on BetaGroup.
        if group.respond_to?(:remove_beta_testers)
          group.remove_beta_testers(beta_tester_ids: tester_ids)
        else
          # Fallback to the lower-level Connect API call directly. Some
          # spaceship versions only expose the model-level add_*; the
          # remove side is reachable via the module function.
          Spaceship::ConnectAPI.delete_beta_groups_beta_testers(
            beta_group_id: group.id, beta_tester_ids: tester_ids
          )
        end
        UI.success "  ✓ Removed #{tester_count} tester(s)"
      rescue => e
        UI.error "  ✗ Failed to remove testers: #{e.message.to_s.lines.first&.strip}"
        UI.user_error!("delete_empty_internal_group: tester removal failed")
      end
    end

    UI.message "Deleting internal beta group '#{group_name}' (id=#{group.id})…"
    group.delete!
    UI.success "✓ Deleted internal beta group '#{group_name}'."
  end

  # -------------------------------------------------------------------------
  # list_groups — print every beta group + which testers belong to each.
  # Useful diagnostic when builds aren't reaching specific testers.
  # -------------------------------------------------------------------------
  desc "List beta groups + tester memberships"
  lane :list_groups do
    asc_api_key   # build the api key object (also sets up env defaults)
    # ConnectAPI.login(api_token:) was removed in newer spaceship —
    # token must be set directly. Same pattern distribute_latest uses.
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id:    ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key:       Base64.decode64(ENV["APP_STORE_CONNECT_KEY_P8"]),
      duration:  1200,
    )
    app = Spaceship::ConnectAPI::App.find("com.aurionclinical.physician")
    UI.user_error! "App not found" unless app
    UI.success "App: #{app.name} (id=#{app.id})"

    UI.message ""
    UI.success "Beta groups:"
    groups = Spaceship::ConnectAPI.get_beta_groups(
      filter: { app: app.id }, limit: 200
    )
    groups.each do |g|
      UI.message "  - #{g.name}  (#{g.is_internal_group ? 'internal' : 'external'})"
    end

    UI.message ""
    UI.success "Testers (all team-wide; 'app' is not a valid BetaTester filter):"
    # No `app:` filter — Apple's API rejects it for BetaTester. We have
    # one app on the team so this returns everyone relevant; with
    # `includes: betaGroups` the group memberships come with each row.
    testers = Spaceship::ConnectAPI.get_beta_testers(
      limit: 200, includes: "betaGroups"
    )
    testers.each do |t|
      names = (t.beta_groups || []).map(&:name).join(", ")
      UI.message "  - #{t.email}  groups=[#{names}]"
    end
  end

  # -------------------------------------------------------------------------
  # list_testers — print current internal testers. Useful for sanity check.
  # -------------------------------------------------------------------------
  desc "List current TestFlight testers"
  lane :list_testers do
    api_key = asc_api_key
    Spaceship::ConnectAPI.login(use_portal: false, use_tunes: true, api_token: api_key)
    app = Spaceship::ConnectAPI::App.find("com.aurionclinical.physician")
    UI.user_error! "App not found — run `fastlane bootstrap` first" unless app

    testers = Spaceship::ConnectAPI::BetaTester.all(app_id: app.id)
    UI.success "#{testers.size} tester(s):"
    testers.each do |t|
      UI.message "  - #{t.email} (#{t.first_name} #{t.last_name})"
    end
  end
end
